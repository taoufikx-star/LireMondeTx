{
  "dependencies": {
    "json-server": "^1.0.0-beta.15"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "http-server": "^14.0.0"
  },
  "scripts": {
    "server": "json-server --watch db.json --port 3000",
